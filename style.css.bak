:root {
    --primary: #F4B400;
    --primary-dark: #d69e00;
    --dark: #2B160C;
    --light: #FAFAFA;
    --text: #333;
    --white: #fff;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Bootstrap overrides */
h1, h2, h3, h4, h5, h6, p, ul {
    margin-bottom: 0;
}

body {
    font-family: 'Inter', sans-serif;
    color: var(--dark);
    line-height: 1.6;
    background-color: var(--light);
}

h1, h2, h3, .logo-title {
    font-family: 'Playfair Display', serif;
}

/* Navbar */
.navbar {
    position: fixed;
    top: 0; width: 100%;
    background: rgba(43, 22, 12, 0.9);
    backdrop-filter: blur(10px);
    z-index: 1000;
    padding: 15px 0;
}

.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px;
}

.logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--primary);
}

.logo-icon {
    font-size: 2rem;
    margin-right: 10px;
}

.logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
}

.logo-title {
    font-size: 1.4rem;
    font-weight: 700;
}

.logo-subtitle {
    font-family: 'Great Vibes', cursive;
    font-size: 1.8rem;
    margin-top: -5px;
}

.nav-links {
    list-style: none;
    display: flex;
    gap: 20px;
}

.nav-links a {
    color: var(--white);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    padding-bottom: 5px;
}

.nav-links a.active, .nav-links a:hover {
    color: var(--primary);
    border-bottom: 2px solid var(--primary);
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 35px;
    margin-left: 30px; /* Espace entre CONTACT et le panier */
}

.cart {
    color: var(--white);
    font-size: 1.2rem;
    position: relative;
    text-decoration: none;
    margin-right: 20px; /* Espace supplémentaire garanti */
}

.cart-count {
    position: absolute;
    top: -8px; right: -10px;
    background: var(--primary);
    color: var(--dark);
    font-size: 0.7rem;
    font-weight: bold;
    padding: 2px 6px;
    border-radius: 50%;
}

.btn {
    padding: 10px 24px;
    border-radius: 5px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: none;
    display: inline-block;
}

.btn-primary {
    background: var(--primary);
    color: var(--dark);
}

.btn-primary:hover { background: var(--primary-dark); }

.btn-outline {
    border: 1px solid var(--primary);
    color: var(--white);
}

.btn-outline:hover { background: rgba(0,0,0,0.5); color: var(--primary); }

.btn-dark {
    background: var(--dark);
    color: var(--white);
    padding: 12px 30px;
}

/* Hero */
.hero {
    background: linear-gradient(rgba(43, 22, 12, 0.7), rgba(43, 22, 12, 0.7)), url('assets/hero_bakery.png') center/cover;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--white);
}

.hero-slogan {
    font-style: italic;
    font-weight: 500;
    font-size: 2.2rem;
}

.hero-title {
    font-family: 'Great Vibes', cursive;
    color: var(--primary);
    font-size: 5.5rem;
    margin: 10px 0 20px;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
}

.hero-desc {
    font-size: 1.1rem;
    margin-bottom: 30px;
    line-height: 1.6;
}

.hero-buttons {
    display: flex;
    gap: 15px;
    justify-content: center;
}

/* Features */
.features {
    background: var(--light);
    display: flex;
    justify-content: center;
    padding: 30px 40px;
    max-width: 1200px;
    margin: 0 auto;
    gap: 3cm;
    border-bottom: 1px solid #eee;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
}

.feature-icon {
    font-size: 1.5rem;
    color: var(--dark);
    border: 1px solid var(--dark);
    border-radius: 50%;
    width: 50px; height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.feature-item h4 {
    font-family: 'Inter', sans-serif;
    color: var(--dark);
    font-size: 1rem;
}

.feature-item p {
    font-size: 0.85rem;
    color: #666;
}

/* Section Title */
.section-title {
    text-align: center;
    font-size: 2.5rem;
    color: var(--dark);
    margin: 50px 0 30px;
}

/* Nos Délices */
.delices {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}

.filters {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 40px;
}

.filter-btn {
    background: #f1f1f1;
    border: none;
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    cursor: pointer;
}

.filter-btn.active, .filter-btn:hover {
    background: var(--primary);
    color: var(--dark);
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
}

.product-card {
    background: var(--white);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    text-align: center;
    transition: transform 0.3s;
}

.product-card:hover { transform: translateY(-5px); }

.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: #e0e0e0;
}

.product-info {
    padding: 15px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
}

.product-info h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.price {
    font-weight: 600;
    color: #555;
    margin-bottom: 15px;
}

.btn-add {
    background: var(--primary);
    border: none;
    padding: 8px 15px;
    border-radius: 20px;
    font-weight: 600;
    margin-top: auto;
    cursor: pointer;
}

.text-center { text-align: center; }
.mt-4 { margin-top: 40px; }

/* Info Cards */
.info-cards {
    max-width: 1200px;
    margin: 60px auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.info-card {
    padding: 30px;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
}

.info-card.dark {
    background: var(--dark);
    color: var(--white);
}

.info-card.yellow {
    background: var(--primary);
    color: var(--dark);
}

.info-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.5rem;
    margin-bottom: 15px;
}

.info-card.dark h3 { color: var(--primary); }

.info-card p {
    font-size: 0.9rem;
    margin-bottom: 20px;
    position: relative; z-index: 2;
    max-width: 70%;
}

.payment-badges {
    display: flex;
    gap: 10px;
}

.badge {
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
}

.badge.mtn { background: var(--primary); color: var(--dark); }
.badge.orange { background: #f16e00; color: var(--white); }
.badge.moov { background: #0066cc; color: var(--white); }
.badge.wave { background: #1dc4e9; color: var(--white); }

.points-badge {
    background: rgba(255,255,255,0.2);
    border: 1px solid var(--primary);
    padding: 5px 15px;
    border-radius: 5px;
    display: inline-block;
    color: var(--primary);
    font-weight: bold;
}

.decor-img {
    position: absolute;
    right: -10px; bottom: -10px;
    height: 150px;
    z-index: 1;
}

/* =========================================
   PROCESS TIMELINE (Comment ça marche)
   ========================================= */
.process {
    background: var(--light);
    padding: 80px 0;
}

.timeline-container {
    padding-top: 20px;
}

.timeline-line {
    position: absolute;
    top: -15px; /* Déplacé au-dessus des icônes */
    left: 12.5%;
    right: 12.5%;
    height: 3px;
    background: linear-gradient(to right, transparent, var(--primary) 10%, var(--primary) 90%, transparent);
    z-index: 1;
    opacity: 0.5;
}

.process-steps {
    position: relative;
    z-index: 2;
}

.step {
    padding: 0 15px;
    transition: transform 0.3s ease;
}

.step:hover {
    transform: translateY(-10px);
}

.step-icon-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 15px;
}

.step-icon {
    width: 80px; 
    height: 80px;
    min-width: 80px; 
    min-height: 80px;
    background: #FDF1D5;
    border: 3px solid #fff;
    color: var(--primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 34px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
}

.step-badge {
    display: inline-block;
    width: 30px;
    height: 30px;
    line-height: 30px;
    text-align: center;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    background: var(--primary);
    border-radius: 50%;
    margin-bottom: 15px;
}

.step h4 {
    color: var(--dark); 
    font-size: 1.5rem; /* 24px */
    font-weight: 700;
    margin-bottom: 10px; 
}

.step p { 
    font-size: 1rem; /* 16px */
    color: #666; 
    line-height: 1.5;
}

@media (max-width: 768px) {
    .step {
        margin-bottom: 40px;
    }
}

/* Footer */
footer {
    background: var(--dark);
    color: var(--white);
    padding: 60px 20px 20px;
}

.footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
}

.footer-col h4 {
    color: var(--white);
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 20px;
}

.footer-desc {
    font-size: 0.9rem;
    color: #ccc;
    margin: 15px 0;
}

.social-icons a {
    color: var(--white);
    background: rgba(255,255,255,0.1);
    width: 35px; height: 35px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    margin-right: 10px;
    text-decoration: none;
}

.footer-col ul {
    list-style: none;
}

.footer-col ul a {
    color: #ccc;
    text-decoration: none;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 10px;
}

.footer-col p {
    color: #ccc;
    font-size: 0.9rem;
    margin-bottom: 10px;
}

.btn-whatsapp {
    background: #25D366;
    color: var(--white);
    text-decoration: none;
    padding: 8px 15px;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 10px;
    font-size: 0.9rem;
    font-weight: bold;
}

.footer-bottom {
    max-width: 1200px;
    margin: 40px auto 0;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #999;
}

.footer-bottom a {
    color: #999;
    text-decoration: none;
    margin-left: 10px;
}

/* =========================================
   A PROPOS PAGE STYLES
   ========================================= */

/* Page Hero */
.page-hero {
    height: 60vh;
    min-height: 400px;
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: var(--white);
    padding: 0 20px;
    position: relative;
    margin-top: 70px;
}

.breadcrumb {
    position: absolute;
    top: 20px;
    left: 10%;
    font-size: 0.9rem;
}
.breadcrumb a {
    color: var(--primary);
    text-decoration: none;
}
.breadcrumb span {
    color: var(--white);
}

.page-hero-content {
    max-width: 800px;
}

.section-badge {
    display: inline-block;
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: bold;
    letter-spacing: 2px;
    margin-bottom: 10px;
    text-transform: uppercase;
}

.page-title {
    font-size: 3.5rem;
    margin-bottom: 15px;
    line-height: 1.2;
}

.page-title .highlight {
    color: var(--primary);
    font-style: italic;
}

.separator-icon {
    color: var(--primary);
    font-size: 1.5rem;
    margin: 20px 0;
}

.page-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 30px;
    color: #ddd;
}

/* History Section */
.history-section {
    padding: 80px 20px;
    background-color: var(--light);
}

.history-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 60px;
    align-items: center;
}

.history-text {
    flex: 1;
}

.history-text h2 {
    font-size: 2.5rem;
    color: var(--dark);
    margin-bottom: 20px;
}

.history-text p {
    color: #555;
    line-height: 1.8;
    margin-bottom: 20px;
}

.signature {
    font-family: 'Great Vibes', cursive;
    font-size: 2.5rem;
    color: var(--primary);
    margin-top: 30px;
}

.history-image {
    flex: 1;
    position: relative;
}

.history-image img {
    width: 100%;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.history-badges {
    position: absolute;
    bottom: -20px;
    right: -20px;
    display: flex;
    gap: 10px;
}

.h-badge {
    background: var(--dark);
    color: var(--white);
    padding: 15px 20px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.h-badge-icon {
    color: var(--primary);
    font-size: 2rem;
}

.h-badge .number {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--white);
}

.h-badge .label {
    font-size: 0.8rem;
    color: #ccc;
}

/* Values Section */
.values-section {
    padding: 80px 20px;
    background-color: #fff;
}

.values-grid {
    max-width: 1200px;
    margin: 50px auto 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    text-align: center;
}

.value-card {
    padding: 30px 20px;
    border: 1px solid #eee;
    border-radius: 10px;
    transition: transform 0.3s;
}

.value-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
}

.v-icon {
    width: 70px;
    height: 70px;
    background: rgba(244, 180, 0, 0.1);
    color: var(--primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin: 0 auto 20px;
}

.value-card h4 {
    color: var(--dark);
    margin-bottom: 15px;
    font-size: 1.2rem;
}

.value-card p {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
}

/* Savoir-Faire Section */
.savoir-faire-section {
    padding: 80px 20px;
    background-color: var(--light);
}

.savoir-faire-section h2 {
    font-size: 2.5rem;
    color: var(--dark);
}

.steps-container {
    max-width: 1200px;
    margin: 50px auto 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.step {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 15px;
}

.step-content {
    flex: 1;
}

.step-number {
    color: var(--primary);
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 5px;
}

.step h4 {
    color: var(--dark);
    margin-bottom: 5px;
    font-size: 1.1rem;
}

.step p {
    color: #666;
    font-size: 0.85rem;
    line-height: 1.4;
}

.step-image {
    width: 80px;
    height: 80px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
}

.step-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.step-arrow {
    color: #ccc;
    font-size: 1.5rem;
    margin: 0 15px;
}

/* Team Section */
.team-section {
    padding: 80px 20px;
    background-color: #fff;
}

.team-section h2 {
    font-size: 2.5rem;
    color: var(--dark);
}

.team-grid {
    max-width: 1200px;
    margin: 50px auto 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    text-align: center;
}

.team-member img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 15px;
}

.team-member h4 {
    color: var(--dark);
    font-size: 1.2rem;
    margin-bottom: 5px;
}

.team-member p {
    color: var(--primary);
    font-size: 0.9rem;
    margin-bottom: 15px;
}

.social-links a {
    display: inline-flex;
    width: 35px;
    height: 35px;
    background: #f5f5f5;
    color: var(--dark);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    margin: 0 5px;
    text-decoration: none;
    transition: 0.3s;
}

.social-links a:hover {
    background: var(--primary);
    color: var(--white);
}

/* Engagements Banner */
.engagements-banner {
    background-color: var(--dark);
    padding: 40px 20px;
    display: flex;
    justify-content: center;
    gap: 40px;
    color: var(--white);
    flex-wrap: wrap;
}

.engagement {
    display: flex;
    align-items: center;
    gap: 15px;
    max-width: 250px;
}

.e-icon {
    color: var(--primary);
    font-size: 2.5rem;
}

.e-text h4 {
    font-size: 1rem;
    margin-bottom: 5px;
}

.e-text p {
    font-size: 0.8rem;
    color: #aaa;
    line-height: 1.4;
}

/* CTA Banner */
.cta-banner {
    padding: 80px 20px;
    background-size: cover;
    background-position: center;
    text-align: center;
    color: var(--white);
}

.cta-content {
    max-width: 800px;
    margin: 0 auto;
}

.cta-banner h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    line-height: 1.2;
}

.cta-banner p {
    font-size: 1.1rem;
    margin-bottom: 30px;
}

.cta-buttons {
    display: flex;
    gap: 15px;
    justify-content: center;
}

/* Responsive Overrides */
@media (max-width: 1024px) {
    .history-container {
        flex-direction: column;
    }
    .history-badges {
        right: 0;
        bottom: -30px;
    }
    .values-grid, .team-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .steps-container {
        flex-direction: column;
        align-items: stretch;
    }
    .step-arrow {
        text-align: center;
        transform: rotate(90deg);
        margin: 15px 0;
    }
}
@media (max-width: 768px) {
    .values-grid, .team-grid {
        grid-template-columns: 1fr;
    }
    .cta-buttons {
        flex-direction: column;
    }
}

/* =========================================
   PRODUITS PAGE STYLES
   ========================================= */

/* Hero */
.products-hero {
    height: 40vh;
    min-height: 300px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    color: var(--white);
    padding: 0 5%;
    margin-top: 70px;
}

.products-hero-content {
    max-width: 800px;
}

.products-hero .page-title {
    font-size: 3rem;
    margin-bottom: 5px;
    font-family: 'Playfair Display', serif;
}

.products-hero .page-subtitle {
    font-size: 2.2rem;
    margin-bottom: 15px;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    color: var(--primary);
}

.products-hero .page-desc {
    font-size: 1.1rem;
    line-height: 1.5;
    color: #eee;
}

/* Features Bar */
.features-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #fff;
    padding: 25px 5%;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    margin-bottom: 40px;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
    color: var(--dark);
    font-size: 0.95rem;
    line-height: 1.4;
}

.feature-item i {
    color: var(--primary-dark);
    font-size: 2rem;
}

/* Shop Layout */
.shop-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    gap: 30px;
    padding: 0 20px 80px;
}

.shop-sidebar {
    width: 280px;
    flex-shrink: 0;
}

.shop-main {
    flex: 1;
}

/* Sidebar Widgets */
.sidebar-widget {
    background: #fff;
    padding: 25px;
    border-radius: 10px;
    margin-bottom: 25px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.03);
}

.sidebar-widget h4 {
    font-size: 1.1rem;
    color: var(--dark);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
}

/* Search Box */
.search-box {
    display: flex;
    align-items: stretch;
    border: 1px solid #ddd;
    border-radius: 5px;
    overflow: hidden; /* Garantit que les coins arrondis s'appliquent à tout */
}

.search-box input {
    flex: 1;
    padding: 10px 15px;
    border: none;
    outline: none;
    background: transparent;
}

.search-box button {
    background: var(--primary);
    color: var(--white);
    border: none;
    padding: 0 20px;
    cursor: pointer;
    transition: 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.search-box button:hover {
    background: var(--primary-dark);
}

/* Categories List */
.categories-widget ul {
    list-style: none;
}

.categories-widget li {
    margin-bottom: 12px;
}

.categories-widget a {
    display: flex;
    align-items: center;
    color: #555;
    text-decoration: none;
    font-size: 0.95rem;
    transition: 0.2s;
}

.categories-widget a i {
    width: 25px;
    color: #999;
}

.categories-widget li.active a, .categories-widget a:hover {
    color: var(--dark);
    font-weight: 600;
}

.categories-widget li.active a i {
    color: var(--primary);
}

.categories-widget .count {
    margin-left: auto;
    color: #999;
    font-size: 0.85rem;
    font-weight: normal;
}

/* Filters */
.filter-group {
    margin-bottom: 25px;
}

.filter-group label {
    display: block;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 10px;
    font-size: 0.95rem;
}

.price-slider {
    width: 100%;
    accent-color: var(--dark);
}

.price-range {
    display: flex;
    justify-content: space-between;
    margin-top: 5px;
    font-size: 0.85rem;
    color: var(--dark);
    font-weight: 600;
}

/* Custom Checkbox */
.checkbox-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.custom-checkbox {
    display: flex;
    align-items: center;
    cursor: pointer;
    font-size: 0.95rem;
    color: #555;
    position: relative;
    padding-left: 30px;
    font-weight: normal !important;
}

.custom-checkbox input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
}

.checkmark {
    position: absolute;
    top: 0;
    left: 0;
    height: 20px;
    width: 20px;
    background-color: #eee;
    border-radius: 4px;
}

.custom-checkbox:hover input ~ .checkmark {
    background-color: #ccc;
}

.custom-checkbox input:checked ~ .checkmark {
    background-color: var(--primary);
}

.checkmark:after {
    content: "";
    position: absolute;
    display: none;
}

.custom-checkbox input:checked ~ .checkmark:after {
    display: block;
}

.custom-checkbox .checkmark:after {
    left: 7px;
    top: 3px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
}

.custom-select {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    outline: none;
    color: #555;
    font-size: 0.9rem;
}

.reset-filters-btn {
    width: 100%;
    font-size: 0.85rem;
    padding: 10px;
    justify-content: center;
    color: var(--dark) !important;
}

.reset-filters-btn:hover {
    background: var(--primary) !important;
    color: var(--dark) !important;
}

/* Shop Header */
.shop-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

.shop-header h3 {
    font-size: 1.3rem;
    color: var(--dark);
}

.header-sort {
    font-size: 0.9rem;
    color: #666;
    display: flex;
    align-items: center;
    gap: 10px;
}

/* Products Grid 4 Cols */
.products-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.product-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: 0.3s;
    position: relative;
    display: flex;
    flex-direction: column;
}

.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.product-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: var(--primary);
    color: var(--dark);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 5px 10px;
    border-radius: 20px;
    z-index: 2;
}

.badge-green {
    background: #4CAF50;
    color: white;
}

.product-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.product-info {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.product-info h4 {
    font-size: 1.1rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.product-info .price {
    font-weight: bold;
    color: var(--dark);
    font-size: 1rem;
    margin-bottom: 10px;
}

.product-info .product-desc {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.4;
    margin-bottom: 15px;
    flex: 1;
}

.product-info .rating {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: bold;
    margin-bottom: 15px;
}

.product-info .rating span {
    color: #999;
    font-weight: normal;
}

.btn-add {
    width: 100%;
    background: #fdf5d3;
    color: var(--dark);
    border: none;
    padding: 10px;
    border-radius: 5px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.3s;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.btn-add:hover {
    background: var(--primary);
    color: var(--white);
}

/* Pagination */
.pagination {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 60px;
}

.page-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: #fff;
    color: var(--dark);
    text-decoration: none;
    border-radius: 50%;
    font-weight: bold;
    transition: 0.3s;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.page-link.active, .page-link:hover {
    background: var(--primary);
    color: var(--dark);
}

.page-dots {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    width: 30px;
    color: #999;
    font-weight: bold;
    padding-bottom: 10px;
}

/* Bottom Banners */
.shop-bottom-banners {
    display: flex;
    gap: 30px;
}

.promo-banner {
    flex: 2;
    border-radius: 15px;
    padding: 30px 40px;
    color: var(--white);
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.promo-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.2);
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 0.85rem;
    margin-bottom: 15px;
}

.promo-banner h3 {
    font-size: 2rem;
    font-family: 'Playfair Display', serif;
    margin-bottom: 15px;
}

.promo-pricing {
    display: flex;
    align-items: center;
    gap: 15px;
}

.new-price {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary);
}

.old-price {
    font-size: 1rem;
    text-decoration: line-through;
    color: #aaa;
}

.promo-timer {
    text-align: center;
}

.timer-label {
    font-size: 0.85rem;
    margin-bottom: 10px;
    color: #ddd;
}

.countdown {
    display: flex;
    align-items: center;
    gap: 10px;
}

.time-box {
    background: rgba(0,0,0,0.5);
    padding: 10px 15px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
}

.time-box span {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary);
    margin-bottom: 2px;
}

.time-box { font-size: 0.7rem; color: #ccc; }

.promo-bg-img {
    position: absolute;
    right: 5%;
    bottom: -20%;
    height: 120%;
    opacity: 0.8;
    z-index: 0;
    pointer-events: none;
}

.promo-content, .promo-timer {
    position: relative;
    z-index: 1;
}

.help-banner {
    flex: 1;
    background: #efebe4;
    border-radius: 15px;
    padding: 30px;
    display: flex;
    gap: 20px;
    align-items: center;
}

.help-icon {
    font-size: 3rem;
    color: var(--primary-dark);
}

.help-content h3 {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 10px;
}

.help-content p {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 15px;
    line-height: 1.4;
}

/* Pre-Footer Reassurance */
.reassurance-banner {
    display: flex;
    justify-content: center;
    gap: 50px;
    padding: 40px 20px;
    background-color: var(--light);
    border-top: 1px solid #ddd;
    flex-wrap: wrap;
}

.r-item {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 0.9rem;
    color: var(--dark);
    font-weight: 500;
}

.r-item i {
    color: var(--primary-dark);
    font-size: 2rem;
}

/* Responsive */
@media (max-width: 1200px) {
    .products-grid-4 {
        grid-template-columns: repeat(3, 1fr);
    }
    .shop-bottom-banners {
        flex-direction: column;
    }
}
@media (max-width: 992px) {
    .shop-container {
        flex-direction: column;
    }
    .shop-sidebar {
        width: 100%;
    }
    .features-bar {
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }
}
@media (max-width: 768px) {
    .products-grid-4 {
        grid-template-columns: repeat(2, 1fr);
    }
    .promo-banner {
        flex-direction: column;
        gap: 20px;
        text-align: center;
    }
    .reassurance-banner {
        gap: 20px;
        justify-content: flex-start;
    }
}
@media (max-width: 480px) {
    .products-grid-4 {
        grid-template-columns: 1fr;
    }
}

/* =========================================
   COMMANDER PAGE STYLES
   ========================================= */

/* Hero & Progress */
.checkout-hero {
    height: 35vh;
    min-height: 250px;
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--white);
    padding: 0 5%;
    position: relative;
    margin-top: 70px;
}

.checkout-hero-content {
    max-width: 800px;
    margin-bottom: 20px;
}

.checkout-hero .page-title {
    font-size: 2.5rem;
    font-family: 'Playfair Display', serif;
    margin-bottom: 10px;
}

.checkout-hero .page-desc {
    font-size: 1.1rem;
    color: #eee;
}

.checkout-progress {
    position: absolute;
    bottom: -35px;
    left: 5%;
    right: 5%;
    background: #fff;
    padding: 15px 30px;
    border-radius: 10px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 10;
}

.progress-step {
    display: flex;
    align-items: center;
    gap: 15px;
}

.step-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #999;
    font-size: 1.1rem;
}

.step-text {
    display: flex;
    flex-direction: column;
}

.step-text strong {
    color: var(--dark);
    font-size: 0.95rem;
}

.step-text span {
    color: #999;
    font-size: 0.8rem;
}

.progress-step.active .step-circle {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--dark);
}

.step-arrow {
    color: #ddd;
    font-size: 1.2rem;
}

/* Layout */
.bg-gray-light {
    background-color: #fcfbf9;
}

.checkout-container {
    max-width: 1400px;
    margin: 80px auto 0;
    display: flex;
    gap: 30px;
    padding: 0 20px 80px;
}

.checkout-left {
    flex: 2;
}

.checkout-right {
    flex: 1;
}

/* Sections */
.checkout-section {
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.03);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
}

.section-header h2 {
    font-size: 1.3rem;
    color: var(--dark);
    display: flex;
    align-items: center;
    gap: 15px;
}

.section-header h2 i {
    color: var(--primary-dark);
}

.edit-link {
    color: #999;
    font-size: 0.9rem;
    text-decoration: none;
    transition: 0.3s;
}

.edit-link:hover {
    color: var(--primary-dark);
}

/* Cart Items */
.cart-items {
    margin-bottom: 25px;
}

.cart-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 15px 0;
    border-bottom: 1px dashed #eee;
}

.cart-item:last-child {
    border-bottom: none;
}

.cart-item img {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
}

.item-details {
    flex: 1;
}

.item-details h4 {
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.item-details span {
    font-size: 0.9rem;
    color: #666;
}

.item-qty {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 5px;
    overflow: hidden;
}

.item-qty button {
    background: #f9f9f9;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    color: #666;
}

.item-qty button:hover {
    background: #eee;
}

.item-qty span {
    padding: 0 15px;
    font-weight: bold;
    color: var(--dark);
}

.item-total {
    font-weight: bold;
    color: var(--dark);
    width: 100px;
    text-align: right;
}

.item-delete {
    background: none;
    border: none;
    color: #ccc;
    font-size: 1.2rem;
    cursor: pointer;
    transition: 0.3s;
}

.item-delete:hover {
    color: #ff4d4d;
}

/* Info Boxes */
.loyalty-box, .delivery-zone-box {
    display: flex;
    align-items: center;
    gap: 20px;
    background: #fdfaf2;
    border: 1px solid #faecca;
    padding: 20px;
    border-radius: 8px;
}

.l-icon, .dz-icon {
    font-size: 2rem;
    color: var(--primary-dark);
}

.l-content, .dz-content {
    flex: 1;
}

.l-content h4, .dz-content h4 {
    color: var(--dark);
    margin-bottom: 5px;
    font-size: 1rem;
}

.l-content p, .dz-content p {
    font-size: 0.85rem;
    color: #666;
}

/* Forms */
.address-options {
    display: flex;
    gap: 30px;
    margin-bottom: 25px;
}

.custom-radio {
    display: flex;
    align-items: center;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--dark);
    position: relative;
    padding-left: 30px;
    font-weight: 600;
}

.custom-radio input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
}

.radiomark {
    position: absolute;
    top: -2px;
    left: 0;
    height: 20px;
    width: 20px;
    background-color: #fff;
    border: 2px solid #ddd;
    border-radius: 50%;
}

.custom-radio:hover input ~ .radiomark {
    border-color: var(--primary);
}

.custom-radio input:checked ~ .radiomark {
    border-color: var(--primary);
}

.radiomark:after {
    content: "";
    position: absolute;
    display: none;
}

.custom-radio input:checked ~ .radiomark:after {
    display: block;
}

.custom-radio .radiomark:after {
    top: 4px;
    left: 4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dark);
}

.address-form {
    margin-bottom: 25px;
}

.form-row {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
}

.form-row.triple .form-group {
    flex: 1;
}

.form-group {
    flex: 1;
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    font-size: 0.9rem;
    color: var(--dark);
    margin-bottom: 8px;
    font-weight: 600;
}

.form-group input, .form-group select {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 0.95rem;
    outline: none;
    transition: 0.3s;
}

.form-group input:focus, .form-group select:focus {
    border-color: var(--primary);
}

/* Delivery Methods */
.delivery-methods {
    display: flex;
    gap: 20px;
}

.method-card {
    flex: 1;
    display: flex;
    align-items: flex-start;
    gap: 15px;
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 8px;
    cursor: pointer;
    transition: 0.3s;
    position: relative;
}

.method-card.active, .method-card:hover {
    border-color: var(--primary);
    background: #fdfaf2;
}

.method-card input {
    position: absolute;
    opacity: 0;
}

.mc-icon {
    font-size: 1.5rem;
    color: var(--primary-dark);
}

.mc-content h4 {
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.mc-content p {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 10px;
}

.mc-time {
    font-size: 0.8rem;
    color: #4CAF50;
    font-weight: bold;
}

.input-with-icon {
    position: relative;
    flex: 1;
}

.input-with-icon i {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #999;
}

.input-with-icon input {
    padding-left: 40px;
}

/* Summary Box */
.summary-box {
    background: #fcfbf9;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 30px;
    margin-bottom: 30px;
}

.summary-box h2 {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #e0e0e0;
}

.summary-line {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    color: #555;
    font-size: 0.95rem;
}

.summary-line.discount span {
    color: #4CAF50;
}

.summary-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #e0e0e0;
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--dark);
}

.points-earned {
    display: flex;
    align-items: center;
    gap: 15px;
    background: #e8f5e9;
    border: 1px solid #c8e6c9;
    padding: 15px;
    border-radius: 8px;
    margin-top: 25px;
}

.points-earned i {
    font-size: 1.5rem;
    color: #4CAF50;
}

.points-earned strong {
    color: #2e7d32;
    font-size: 0.95rem;
    display: block;
    margin-bottom: 3px;
}

.points-earned p {
    color: #388e3c;
    font-size: 0.8rem;
}

/* Payment Box */
.payment-box {
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 2px 15px rgba(0,0,0,0.03);
}

.payment-box h2 {
    font-size: 1.2rem;
    color: var(--dark);
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
}

.payment-methods {
    display: flex;
    flex-direction: column;
    gap: 15px;
    margin-bottom: 25px;
}

.payment-card {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    border: 1px solid #ddd;
    border-radius: 8px;
    cursor: pointer;
    transition: 0.3s;
    position: relative;
}

.payment-card.active {
    border-color: var(--primary);
    background: #fdfaf2;
}

.payment-card input {
    position: absolute;
    opacity: 0;
}

.payment-card.active::after {
    content: "\f058";
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    position: absolute;
    right: 20px;
    color: var(--primary);
    font-size: 1.2rem;
}

.pc-logo {
    width: 40px;
    height: 40px;
    border-radius: 5px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
}

.pc-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #d1bfae;
}

.pc-content h4 {
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 3px;
}

.pc-content p {
    font-size: 0.8rem;
    color: #666;
}

/* Logos Mobile Money (CSS Drawing) */
.orange-money-logo {
    width: 20px;
    height: 20px;
    border: 4px solid #f16e00;
    border-radius: 5px;
}
.mtn-money-logo {
    width: 25px;
    height: 15px;
    background: #ffcc00;
    border-radius: 10px;
}
.moov-money-logo {
    width: 20px;
    height: 20px;
    border: 3px solid #0066cc;
    border-radius: 50%;
}
.wave-money-logo {
    width: 25px;
    height: 25px;
    background: #1cd0fd;
    border-radius: 5px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 14px;
    font-family: Arial, sans-serif;
}
.wave-money-logo::after {
    content: "W";
}

.secure-payment-info {
    display: flex;
    align-items: center;
    gap: 15px;
    background: #fdfaf2;
    border: 1px solid #faecca;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 25px;
}

.spi-icon {
    font-size: 2rem;
    color: #d1bfae;
}

.spi-text {
    flex: 1;
}

.spi-text h4 {
    font-size: 0.95rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.spi-text p {
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 8px;
}

.spi-logos {
    display: flex;
    gap: 10px;
}

.spi-lock {
    font-size: 1.5rem;
    color: #d1bfae;
    opacity: 0.5;
}

.btn-large {
    padding: 15px;
    font-size: 1.1rem;
}

.terms-text {
    text-align: center;
    font-size: 0.8rem;
    color: #999;
    margin-top: 15px;
    line-height: 1.5;
}

.terms-text a {
    color: #c98a58;
    text-decoration: none;
}

/* Why Order Banner */
.why-order-banner {
    background: #fdfaf2;
    padding: 50px 20px;
    text-align: center;
}

.why-order-banner h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin-bottom: 40px;
}

.why-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 30px;
    flex-wrap: wrap;
}

.w-item {
    display: flex;
    align-items: center;
    gap: 15px;
    text-align: left;
    max-width: 220px;
}

.w-item i {
    font-size: 2rem;
    color: var(--primary-dark);
}

.w-item h4 {
    font-size: 0.95rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.w-item p {
    font-size: 0.8rem;
    color: #666;
    line-height: 1.4;
}

/* Responsive */
@media (max-width: 1024px) {
    .checkout-container {
        flex-direction: column;
    }
    .checkout-progress {
        display: none; /* Hide progress bar on small screens to save space */
    }
}
@media (max-width: 768px) {
    .delivery-methods, .form-row {
        flex-direction: column;
        gap: 15px;
    }
    .cart-item {
        flex-wrap: wrap;
    }
    .why-grid {
        justify-content: flex-start;
    }
}

/* =========================================
   LIVRAISON PAGE STYLES
   ========================================= */

/* Hero Section */
.delivery-hero {
    background-image: linear-gradient(rgba(43, 22, 12, 0.8), rgba(43, 22, 12, 0.8)), url('assets/scooter_livraison.png');
    background-size: cover;
    background-position: center;
    padding: 120px 5% 80px;
    color: var(--white);
    margin-top: 70px;
}

.delivery-hero-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 50px;
}

.dh-content {
    flex: 1;
    max-width: 700px;
}

.dh-badge {
    display: inline-block;
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
    padding: 8px 15px;
    border-radius: 5px;
    font-size: 0.85rem;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 20px;
}

.dh-title {
    font-size: 3.5rem;
    font-family: 'Playfair Display', serif;
    line-height: 1.1;
    margin-bottom: 25px;
    color: #fff;
}

.dh-desc {
    font-size: 1.1rem;
    color: #ddd;
    margin-bottom: 35px;
    line-height: 1.6;
}

.dh-buttons {
    display: flex;
    gap: 20px;
}

.dh-features {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.dh-feature-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 15px 25px;
    border-radius: 12px;
    transition: 0.3s;
}

.dh-feature-card:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateX(-10px);
}

.dhf-icon {
    font-size: 1.8rem;
    color: var(--primary);
    width: 40px;
    text-align: center;
}

.dhf-text {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.4;
}

/* Features Bar */
.delivery-features-bar {
    background: #fff;
    padding: 40px 5%;
    border-bottom: 1px solid #eee;
}

.df-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 30px;
    flex-wrap: wrap;
}

.df-item {
    flex: 1;
    min-width: 250px;
    display: flex;
    align-items: flex-start;
    gap: 15px;
}

.dfi-icon {
    font-size: 2.2rem;
    color: #d1bfae;
}

.dfi-content h4 {
    color: var(--dark);
    font-size: 1rem;
    margin-bottom: 8px;
}

.dfi-content p {
    color: #666;
    font-size: 0.85rem;
    line-height: 1.5;
}

/* Zones de livraison */
.delivery-zones-section {
    padding: 80px 5%;
    background: #fdfaf2;
}

.dz-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    gap: 50px;
    align-items: flex-start;
}

.dz-content {
    flex: 1;
}

.section-badge {
    color: #c98a58;
    font-weight: bold;
    font-size: 0.85rem;
    letter-spacing: 1px;
    margin-bottom: 15px;
}

.section-title {
    font-size: 2.5rem;
    font-family: 'Playfair Display', serif;
    color: var(--dark);
    margin-bottom: 40px;
    line-height: 1.2;
}

.zones-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.zone-item {
    display: flex;
    align-items: center;
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    border-left: 5px solid transparent;
}

.zone-item.green { border-left-color: #4CAF50; }
.zone-item.blue { border-left-color: #2196F3; }
.zone-item.yellow { border-left-color: #FFC107; }
.zone-item.purple { border-left-color: #9C27B0; }

.zone-dot {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    margin-right: 20px;
}

.zone-item.green .zone-dot { background: #4CAF50; }
.zone-item.blue .zone-dot { background: #2196F3; }
.zone-item.yellow .zone-dot { background: #FFC107; }
.zone-item.purple .zone-dot { background: #9C27B0; }

.zone-info {
    flex: 1;
}

.zone-info h4 {
    color: var(--dark);
    font-size: 1.1rem;
    margin-bottom: 5px;
}

.zone-info p {
    color: #666;
    font-size: 0.9rem;
}

.zone-price {
    font-weight: bold;
    color: #4CAF50;
    font-size: 1.1rem;
}

.dz-map {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.empty-map-placeholder {
    width: 100%;
    height: 500px;
    background: #e9e5db;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed #d1bfae;
    color: #a89a8c;
    font-weight: bold;
    font-size: 1.2rem;
    text-align: center;
}

.map-note {
    text-align: center;
    font-size: 0.85rem;
    color: #777;
    margin-top: 15px;
}

/* Comment ça marche */
.how-it-works-section {
    padding: 80px 5%;
    background: #fff;
}

.timeline-container {
    max-width: 1200px;
    margin: 60px auto 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
}

.timeline-step {
    flex: 1;
    text-align: center;
    position: relative;
    padding: 0 15px;
}

.ts-icon {
    width: 80px;
    height: 80px;
    background: #fdfaf2;
    border: 2px solid #faecca;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 2rem;
    color: var(--primary-dark);
    position: relative;
}

.ts-number {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--primary);
    color: var(--dark);
    width: 25px;
    height: 25px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.9rem;
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
}

.timeline-step h4 {
    color: var(--dark);
    margin-bottom: 10px;
    font-size: 1.1rem;
}

.timeline-step p {
    color: #666;
    font-size: 0.85rem;
    line-height: 1.5;
}

.ts-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 80px;
    color: #ddd;
    font-size: 1.5rem;
    padding: 0 10px;
}

/* Délais et Suivi */
.delivery-times-tracking {
    padding: 80px 5%;
    background: #fcfbf9;
}

.dtt-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    gap: 40px;
}

.delais-box {
    flex: 1;
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.03);
}

.delais-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 30px;
}

.delai-card {
    flex: 1;
    min-width: 150px;
    padding: 25px 20px;
    border-radius: 10px;
    text-align: center;
}

.delai-card.green-bg {
    background: #e8f5e9;
    border: 1px solid #c8e6c9;
}

.delai-card.blue-bg {
    background: #e3f2fd;
    border: 1px solid #bbdefb;
}

.delai-card.purple-bg {
    background: #f3e5f5;
    border: 1px solid #e1bee7;
    min-width: 100%;
}

.dc-icon {
    font-size: 2rem;
    margin-bottom: 15px;
}

.green-bg .dc-icon { color: #4CAF50; }
.blue-bg .dc-icon { color: #2196F3; }
.purple-bg .dc-icon { color: #9C27B0; }

.delai-card h3 {
    font-size: 1.5rem;
    color: var(--dark);
    margin-bottom: 5px;
}

.delai-card h4 {
    font-size: 1rem;
    color: var(--dark);
    margin-bottom: 10px;
}

.delai-card p {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.4;
}

.delais-note {
    background: #fdfaf2;
    padding: 15px;
    text-align: center;
    border-radius: 5px;
    margin-top: 25px;
    font-size: 0.85rem;
    color: #c98a58;
}

.suivi-box {
    flex: 2;
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    display: flex;
    flex-direction: column;
}

.suivi-desc {
    color: #666;
    margin-bottom: 30px;
}

.suivi-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.suivi-progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 40px;
}

.sp-step {
    text-align: center;
    position: relative;
}

.sp-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #f5f5f5;
    color: #ccc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 15px;
    border: 2px solid #eee;
}

.sp-step.active .sp-icon {
    background: #4CAF50;
    color: #fff;
    border-color: #4CAF50;
}

.sp-step span {
    font-size: 0.9rem;
    color: #999;
    font-weight: 500;
}

.sp-step.active span {
    color: var(--dark);
}

.sp-line {
    flex: 1;
    height: 2px;
    background: #eee;
    margin: 0 10px;
    position: relative;
    top: -15px;
}

.suivi-note {
    background: #f9f9f9;
    padding: 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    text-align: center;
    border-left: 4px solid var(--primary);
}

.phone-preview-placeholder {
    display: none; /* Can be shown on larger screens if integrated */
}

/* Engagement Banner */
.engagement-banner {
    background: #2b160c;
    color: #fff;
    padding: 60px 5%;
}

.eb-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 30px;
}

.eb-title {
    display: flex;
    align-items: center;
    gap: 20px;
}

.eb-title i {
    font-size: 3rem;
    color: var(--primary);
}

.eb-title span {
    color: var(--primary);
    font-size: 0.85rem;
    letter-spacing: 1px;
    font-weight: bold;
}

.eb-title h2 {
    font-size: 2rem;
    font-family: 'Playfair Display', serif;
}

.eb-features {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
}

.eb-feature {
    display: flex;
    align-items: center;
    gap: 15px;
}

.eb-feature i {
    font-size: 1.8rem;
    color: var(--primary-dark);
}

.eb-feature span {
    font-size: 0.95rem;
    line-height: 1.4;
}

/* Responsive */
@media (max-width: 1024px) {
    .delivery-hero-container {
        flex-direction: column;
    }
    .dh-content, .dh-features {
        width: 100%;
        max-width: 100%;
    }
    .dh-features {
        flex-direction: row;
        flex-wrap: wrap;
    }
    .dh-feature-card {
        flex: 1;
        min-width: 200px;
    }
    .dz-container {
        flex-direction: column;
    }
    .dtt-container {
        flex-direction: column;
    }
}
@media (max-width: 768px) {
    .timeline-container {
        flex-direction: column;
        align-items: center;
        gap: 30px;
    }
    .ts-arrow {
        transform: rotate(90deg);
        height: 40px;
    }
    .dh-title {
        font-size: 2.5rem;
    }
    .suivi-progress {
        flex-direction: column;
        gap: 20px;
    }
    .sp-line {
        width: 2px;
        height: 30px;
        margin: 10px 0;
        top: 0;
    }
}

/* =========================================
   FIDELITE PAGE STYLES
   ========================================= */

/* Hero Section */
.fidelity-hero {
    background-image: linear-gradient(rgba(43, 22, 12, 0.85), rgba(43, 22, 12, 0.85)), url('assets/carousel_pastries.png');
    background-size: cover;
    background-position: center;
    padding: 120px 5% 80px;
    color: var(--white);
    margin-top: 70px;
}

.fidelity-hero-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 50px;
}

.fh-content {
    flex: 1;
    max-width: 750px;
}

.fh-badge {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.fh-title {
    font-size: 3.5rem;
    font-family: 'Playfair Display', serif;
    line-height: 1.1;
    margin-bottom: 25px;
    color: #fff;
}

.fh-title .highlight-italic {
    font-family: 'Great Vibes', cursive;
    color: var(--primary);
    font-size: 4.5rem;
    font-weight: normal;
    display: block;
    margin-top: -10px;
}

.fh-desc {
    font-size: 1.1rem;
    color: #ddd;
    margin-bottom: 35px;
    line-height: 1.6;
}

.fh-buttons {
    display: flex;
    gap: 20px;
}

.btn-outline-light {
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    padding: 12px 25px;
    border-radius: 5px;
    text-decoration: none;
    font-weight: 500;
    transition: 0.3s;
}

.btn-outline-light:hover {
    background: rgba(255,255,255,0.1);
    border-color: #fff;
}

/* Balance Card */
.fh-card-wrapper {
    flex: 0 0 400px;
}

.fidelity-balance-card {
    background: rgba(20, 10, 5, 0.6);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 204, 102, 0.2);
    border-radius: 12px;
    padding: 30px;
    color: #fff;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.fbc-header {
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.fbc-points {
    font-family: 'Playfair Display', serif;
    font-size: 4.5rem;
    color: var(--primary);
    line-height: 1;
}

.fbc-label {
    font-size: 0.9rem;
    letter-spacing: 2px;
    color: #aaa;
    margin-bottom: 20px;
}

.fbc-desc {
    font-size: 0.85rem;
    color: #ddd;
    line-height: 1.4;
    margin-bottom: 25px;
}

.fbc-progress-bar {
    background: rgba(255,255,255,0.1);
    height: 8px;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 10px;
}

.fbc-progress {
    background: var(--primary);
    height: 100%;
    border-radius: 4px;
}

.fbc-progress-text {
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 25px;
}

.fbc-link {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: 0.3s;
}

.fbc-link:hover {
    color: #fff;
}

/* Features Ribbon */
.fidelity-features-bar {
    background: #fdfaf2;
    padding: 30px 5%;
    border-bottom: 1px solid #eee;
}

.ff-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
}

.ff-item {
    flex: 1;
    min-width: 200px;
    display: flex;
    align-items: center;
    gap: 15px;
    border-right: 1px solid #eee;
}

.ff-item:last-child {
    border-right: none;
}

.ff-item i {
    font-size: 2rem;
    color: #d1bfae;
}

.ff-text strong {
    font-size: 0.85rem;
    color: var(--dark);
}

.ff-text span {
    font-size: 0.8rem;
    color: #666;
    line-height: 1.3;
    display: block;
    margin-top: 3px;
}

/* How it works */
.fidelity-step .ts-icon {
    background: #fff;
    border-color: #eee;
}
.fidelity-step .ts-number {
    background: var(--primary-dark);
    color: #fff;
}

/* Tiers Section */
.fidelity-tiers-section {
    padding: 80px 5%;
    background: #fff;
}

.tiers-container {
    max-width: 1400px;
    margin: 60px auto 0;
    display: flex;
    gap: 25px;
    flex-wrap: wrap;
}

.tier-card {
    flex: 1;
    min-width: 250px;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.tier-card.bronze { background: #faf5eb; border: 1px solid #f0e4d3; }
.tier-card.silver { background: #f5f6fa; border: 1px solid #e1e4ec; }
.tier-card.gold { background: #fffcf2; border: 1px solid #fbeeb0; }
.tier-card.platinum { background: #222; color: #fff; border: 1px solid #333; }

.tier-header {
    text-align: center;
    padding: 30px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.05);
}
.tier-card.platinum .tier-header { border-bottom-color: rgba(255,255,255,0.1); }

.tier-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
    font-size: 1.8rem;
}

.bronze .tier-icon { background: #cd7f32; color: #fff; }
.silver .tier-icon { background: #bdc3c7; color: #fff; }
.gold .tier-icon { background: #f1c40f; color: #fff; }
.platinum .tier-icon { background: var(--primary); color: var(--dark); }

.tier-header h3 {
    font-size: 1.5rem;
    margin-bottom: 5px;
    letter-spacing: 1px;
}
.tier-card.platinum h3 { color: var(--primary); }

.tier-points {
    font-size: 0.9rem;
    font-weight: 500;
}
.tier-card.bronze .tier-points { color: #8d5e2a; }
.tier-card.silver .tier-points { color: #7f8c8d; }
.tier-card.gold .tier-points { color: #d4ac0d; }
.tier-card.platinum .tier-points { color: #ccc; }

.tier-benefits {
    list-style: none;
    padding: 30px 25px;
    flex: 1;
}

.tier-benefits li {
    font-size: 0.9rem;
    margin-bottom: 15px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.4;
}

.bronze .tier-benefits i { color: #cd7f32; }
.silver .tier-benefits i { color: #95a5a6; }
.gold .tier-benefits i { color: #f1c40f; }
.platinum .tier-benefits i { color: var(--primary); }

.tier-footer {
    padding: 15px;
    text-align: center;
    font-size: 0.85rem;
    font-weight: bold;
    text-transform: uppercase;
}

.bronze .tier-footer { background: #efdcb9; color: #8d5e2a; }
.silver .tier-footer { background: #e8eaef; color: #7f8c8d; }
.gold .tier-footer { background: #faeeca; color: #d4ac0d; }
.platinum .tier-footer { background: #111; color: var(--primary); }

.tier-footer.current {
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.05);
}

/* Rewards Grid */
.rewards-section {
    padding: 80px 5%;
    background: #fdfaf2;
}

.rewards-grid {
    max-width: 1400px;
    margin: 50px auto 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
}

.reward-card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    position: relative;
    transition: 0.3s;
}

.reward-card:hover {
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    transform: translateY(-5px);
}

.reward-points {
    position: absolute;
    top: -15px;
    left: 15px;
    background: var(--primary);
    color: var(--dark);
    padding: 5px 12px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.reward-card img {
    width: 100%;
    height: 150px;
    object-fit: contain;
    margin-bottom: 20px;
    margin-top: 15px;
}

.reward-card h4 {
    font-size: 1rem;
    color: var(--dark);
    line-height: 1.4;
}

/* FAQ */
.faq-section {
    padding: 80px 5%;
    background: #fff;
}

.faq-grid {
    max-width: 1000px;
    margin: 50px auto 0;
    display: flex;
    gap: 30px;
}

.faq-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.faq-item {
    border: 1px solid #eaeaea;
    padding: 20px 25px;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: 0.3s;
    background: #fafafa;
}

.faq-item:hover {
    border-color: #ccc;
    background: #fff;
}

.faq-item span {
    font-size: 0.95rem;
    color: var(--dark);
    font-weight: 500;
}

.faq-item i {
    color: #999;
    font-size: 1.2rem;
}

/* Responsive */
@media (max-width: 1024px) {
    .fidelity-hero-container {
        flex-direction: column;
    }
    .fh-content {
        max-width: 100%;
        text-align: center;
    }
    .fh-badge {
        justify-content: center;
    }
    .fh-buttons {
        justify-content: center;
    }
    .ff-item {
        border-right: none;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
    }
    .ff-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .faq-grid {
        flex-direction: column;
    }
}
@media (max-width: 768px) {
    .fh-title {
        font-size: 2.5rem;
    }
    .fh-title .highlight-italic {
        font-size: 3.5rem;
    }
    .eb-container.align-items-center {
        flex-direction: column;
        text-align: center;
    }
    .eb-features {
        flex-direction: column;
        align-items: center;
    }
    .eb-features .btn-primary {
        margin-left: 0 !important;
        margin-top: 20px;
    }
}

/* =========================================
   CONTACT PAGE STYLES
   ========================================= */

/* Hero Section */
.contact-hero {
    background-image: linear-gradient(rgba(20, 10, 5, 0.8), rgba(20, 10, 5, 0.9)), url('assets/hero_bakery.png');
    background-size: cover;
    background-position: center;
    padding: 120px 5% 60px;
    color: var(--white);
    margin-top: 70px;
}

.contact-hero-container {
    max-width: 1400px;
    margin: 0 auto;
    text-align: left;
}

.ch-badge {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: bold;
    letter-spacing: 1px;
    margin-bottom: 20px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
}

.ch-title {
    font-size: 3.5rem;
    font-family: 'Playfair Display', serif;
    line-height: 1.1;
    margin-bottom: 25px;
    color: #fff;
}

.ch-title .highlight-italic {
    font-family: 'Great Vibes', cursive;
    color: var(--primary);
    font-size: 4.5rem;
    font-weight: normal;
    display: block;
    margin-top: -10px;
}

.ch-desc {
    font-size: 1.1rem;
    color: #ddd;
    margin-bottom: 50px;
    line-height: 1.6;
    max-width: 600px;
}

.ch-features {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 40px;
}

.ch-feature {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    flex: 1;
    min-width: 200px;
}

.ch-feature i {
    color: var(--primary);
    font-size: 1.8rem;
}

.chf-text {
    font-size: 0.85rem;
    color: #aaa;
    line-height: 1.4;
}

.chf-text strong {
    color: #fff;
    font-size: 0.95rem;
    display: block;
    margin-bottom: 5px;
}

/* Main Contact Section */
.contact-main-section {
    padding: 80px 5%;
    background: #fcfbf9;
}

.cms-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    gap: 40px;
    align-items: stretch;
}

.cms-form-box, .cms-info-box {
    background: #fff;
    border-radius: 12px;
    padding: 50px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.03);
    flex: 1;
}

/* Contact Form */
.contact-form {
    margin-top: 30px;
}

.form-row-contact {
    display: flex;
    gap: 20px;
}

.form-group-contact {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.form-group-contact label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--dark);
    margin-bottom: 8px;
}

.form-group-contact input,
.form-group-contact select,
.form-group-contact textarea {
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--dark);
    transition: 0.3s;
    background: #fafafa;
}

.form-group-contact input:focus,
.form-group-contact select:focus,
.form-group-contact textarea:focus {
    outline: none;
    border-color: var(--primary-dark);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(201, 138, 88, 0.1);
}

.select-wrapper {
    position: relative;
}

.select-wrapper select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
}

.select-wrapper i {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #999;
    pointer-events: none;
}

.mt-15 { margin-top: 15px; }
.mt-20 { margin-top: 20px; }
.btn-block { width: 100%; display: block; text-align: center; }

.security-note {
    text-align: center;
    font-size: 0.8rem;
    color: #888;
    margin-top: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.security-note i {
    color: #aaa;
}

/* Info Box */
.contact-details {
    margin-top: 30px;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.cd-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
}

.cd-icon {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: #2b160c;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.cd-text {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.5;
}

.cd-text strong {
    display: block;
    color: var(--dark);
    margin-bottom: 5px;
    font-size: 1rem;
}

.map-container {
    margin-top: 20px;
}

.empty-map-placeholder-small {
    width: 100%;
    height: 250px;
    background: #e9e5db;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed #d1bfae;
    color: #a89a8c;
    font-weight: bold;
    font-size: 1rem;
    text-align: center;
}

.btn-dark-brown {
    background: #2b160c;
    color: #fff;
    padding: 15px;
    font-weight: bold;
    transition: 0.3s;
}

.btn-dark-brown:hover {
    background: #422415;
    color: #fff;
}

/* Socials & Boutiques Grid */
.socials-section {
    padding: 40px 5%;
    background: #fdfaf2;
}

.socials-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
}

.social-card {
    background: #fff;
    padding: 30px 20px;
    border-radius: 12px;
    text-align: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    border: 1px solid #f0f0f0;
    transition: 0.3s;
}

.social-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

.sc-icon {
    font-size: 2.5rem;
    margin-bottom: 15px;
}

.whatsapp-color { color: #25D366; }
.insta-color { color: #E1306C; }
.fb-color { color: #1877F2; }
.store-color { color: #c98a58; }

.social-card h4 {
    color: var(--dark);
    font-size: 1.1rem;
    margin-bottom: 10px;
}

.social-card p {
    color: #666;
    font-size: 0.85rem;
    margin-bottom: 25px;
    line-height: 1.4;
}

.btn-sc {
    display: inline-block;
    padding: 10px 15px;
    border-radius: 5px;
    font-size: 0.8rem;
    font-weight: bold;
    text-decoration: none;
    transition: 0.3s;
    background: transparent;
}

.whatsapp-btn { border: 1px solid #25D366; color: #25D366; }
.whatsapp-btn:hover { background: #25D366; color: #fff; }

.insta-btn { border: 1px solid #E1306C; color: #E1306C; }
.insta-btn:hover { background: #E1306C; color: #fff; }

.fb-btn { border: 1px solid #1877F2; color: #1877F2; }
.fb-btn:hover { background: #1877F2; color: #fff; }

.store-btn { border: 1px solid #c98a58; color: #c98a58; }
.store-btn:hover { background: #c98a58; color: #fff; }

/* Special Request Banner */
.special-request-banner {
    position: relative;
    padding: 60px 5%;
    margin-top: 40px;
    overflow: hidden;
}

.srb-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(rgba(20, 10, 5, 0.9), rgba(20, 10, 5, 0.9)), url('assets/product_baguette.png');
    background-size: cover;
    background-position: center;
    z-index: 1;
}

.srb-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
}

.srb-text h2 {
    color: #fff;
    font-size: 2rem;
    font-family: 'Playfair Display', serif;
    margin-bottom: 10px;
}

.srb-text p {
    color: #ccc;
    font-size: 1rem;
}

/* Responsive */
@media (max-width: 1024px) {
    .cms-container {
        flex-direction: column;
    }
    .cms-form-box, .cms-info-box {
        padding: 30px 20px;
    }
    .srb-container {
        text-align: center;
        justify-content: center;
    }
}
@media (max-width: 768px) {
    .form-row-contact {
        flex-direction: column;
        gap: 15px;
    }
    .ch-title {
        font-size: 2.5rem;
    }
    .ch-title .highlight-italic {
        font-size: 3.5rem;
    }
}

/* =========================================
   LOGIN PAGE STYLES
   ========================================= */

.login-wrapper {
    background: #fdfaf2;
    min-height: calc(100vh - 70px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 5%;
    margin-top: 70px;
}

.login-container {
    max-width: 1200px;
    width: 100%;
    display: flex;
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0,0,0,0.08);
}

/* Left Side */
.login-left {
    flex: 1.2;
    position: relative;
    padding: 60px 50px;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.ll-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(to right, rgba(20, 10, 5, 0.95), rgba(20, 10, 5, 0.7)), url('assets/hero_bakery.png');
    background-size: cover;
    background-position: center;
    z-index: 1;
}

.ll-content {
    position: relative;
    z-index: 2;
}

.ll-header {
    margin-bottom: 50px;
}

.ll-icon {
    color: var(--primary);
    font-size: 1.5rem;
    margin-bottom: 20px;
}

.ll-header h2 {
    font-size: 2.8rem;
    font-family: 'Playfair Display', serif;
    line-height: 1.1;
    margin-bottom: 20px;
}

.ll-header .highlight-italic {
    font-family: 'Great Vibes', cursive;
    color: var(--primary);
    font-size: 3.5rem;
    font-weight: normal;
}

.ll-header p {
    color: #ddd;
    font-size: 1.05rem;
    line-height: 1.6;
}

.ll-features {
    display: flex;
    flex-direction: column;
    gap: 30px;
}

.ll-feature {
    display: flex;
    align-items: flex-start;
    gap: 15px;
}

.llf-icon {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 1px solid rgba(201, 138, 88, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    font-size: 1.1rem;
    flex-shrink: 0;
}

.llf-text strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 5px;
}

.llf-text {
    color: #bbb;
    font-size: 0.9rem;
    line-height: 1.5;
}

/* Right Side (Form) */
.login-right {
    flex: 1;
    background: #fff;
    padding: 60px 50px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.lr-form-card {
    width: 100%;
    max-width: 400px;
}

.lr-header {
    margin-bottom: 30px;
}

.lr-user-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid var(--primary);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin: 0 auto 15px;
}

.lr-header h2 {
    font-size: 2.2rem;
    font-family: 'Playfair Display', serif;
    color: var(--dark);
    margin-bottom: 10px;
}

.form-group-login {
    margin-bottom: 20px;
}

.form-group-login label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 8px;
}

.input-with-icon {
    position: relative;
}

.input-with-icon input {
    width: 100%;
    padding: 15px 45px 15px 45px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    background: #fafafa;
    transition: 0.3s;
}

.input-with-icon input:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(201, 138, 88, 0.1);
}

.input-icon-left {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #888;
}

.input-icon-right {
    position: absolute;
    right: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: #888;
    cursor: pointer;
}

.form-actions-login {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    font-size: 0.85rem;
}

/* Custom Checkbox */
.checkbox-container {
    display: flex;
    align-items: center;
    cursor: pointer;
    position: relative;
    padding-left: 25px;
    color: #555;
    user-select: none;
}

.checkbox-container input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
}

.checkmark {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    height: 18px;
    width: 18px;
    background-color: #eee;
    border-radius: 4px;
    transition: 0.2s;
}

.checkbox-container:hover input ~ .checkmark {
    background-color: #ccc;
}

.checkbox-container input:checked ~ .checkmark {
    background-color: var(--primary);
}

.checkmark:after {
    content: "";
    position: absolute;
    display: none;
}

.checkbox-container input:checked ~ .checkmark:after {
    display: block;
}

.checkbox-container .checkmark:after {
    left: 6px;
    top: 3px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
}

.forgot-password {
    color: var(--primary-dark);
    font-weight: 600;
}

.forgot-password:hover {
    text-decoration: underline;
}

.btn-login {
    padding: 15px;
    font-size: 1rem;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.social-login-divider {
    text-align: center;
    margin: 30px 0;
    position: relative;
}

.social-login-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1px;
    background: #e0e0e0;
}

.social-login-divider span {
    background: #fff;
    padding: 0 15px;
    position: relative;
    color: #888;
    font-size: 0.85rem;
}

.social-login-buttons {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
}

.btn-sso {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #fff;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--dark);
    cursor: pointer;
    transition: 0.3s;
}

.btn-sso:hover {
    background: #f5f5f5;
}

.btn-sso img {
    width: 16px;
    height: 16px;
}

.btn-facebook i {
    color: #1877F2;
    font-size: 1.1rem;
}

.btn-apple i {
    font-size: 1.1rem;
}

.lr-footer {
    text-align: center;
    background: #fcfbf9;
    padding: 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #555;
}

.lr-footer a {
    color: var(--primary-dark);
    font-weight: bold;
    display: inline-block;
    margin-top: 5px;
}

.lr-footer a i {
    margin-left: 5px;
    font-size: 0.8rem;
    transition: 0.3s;
}

.lr-footer a:hover i {
    transform: translateX(5px);
}

/* Responsive */
@media (max-width: 992px) {
    .login-container {
        flex-direction: column;
    }
    .login-left, .login-right {
        padding: 40px 30px;
    }
}
@media (max-width: 576px) {
    .social-login-buttons {
        flex-direction: column;
    }
    .ll-header h2 {
        font-size: 2.2rem;
    }
    .ll-header .highlight-italic {
        font-size: 2.8rem;
    }
}

/* =========================================
   REGISTER PAGE STYLES (Extends Login Styles)
   ========================================= */

.highlight-playfair-yellow {
    font-family: 'Playfair Display', serif;
    color: var(--primary);
    font-weight: 700;
}

.form-row-register {
    display: flex;
    gap: 15px;
}

.form-row-register .form-group-login {
    flex: 1;
}

/* Phone Input Group with Country Code */
.phone-input-group {
    display: flex;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #fafafa;
    overflow: hidden;
    transition: 0.3s;
}

.phone-input-group:focus-within {
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(201, 138, 88, 0.1);
}

.country-select {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 15px;
    background: #f5f5f5;
    border-right: 1px solid #e0e0e0;
    cursor: pointer;
    font-weight: 500;
    color: var(--dark);
    font-size: 0.95rem;
}

.country-select i {
    font-size: 0.75rem;
    color: #888;
}

.phone-input-group input {
    flex: 1;
    border: none;
    padding: 15px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    background: transparent;
}

.phone-input-group input:focus {
    outline: none;
}

@media (max-width: 576px) {
    .form-row-register {
        flex-direction: column;
        gap: 0;
    }
}

/* =========================================
   FEATURES BAR (Barre d'avantages)
   ========================================= */
.features-bar {
    background-color: #fff;
    padding: 35px 0;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
}

.fb-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3cm;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
}

.feature-item i {
    font-size: 2.2rem;
    color: var(--primary);
}

.feature-text h4 {
    font-size: 1.05rem;
    color: var(--dark);
    margin-bottom: 5px;
    font-weight: 700;
}

.feature-text p {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0;
}

@media (max-width: 992px) {
    .fb-container {
        flex-wrap: wrap;
    }
    .feature-item {
        width: 45%;
        margin-bottom: 20px;
    }
}

@media (max-width: 576px) {
    .feature-item {
        width: 100%;
    }
}
